{
  "name": "knitto-browser-agent",
  "version": "1.0.0",
  "description": "Knitto Browser Agent web application with Cursor SDK + Puppeteer MCP",
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -n web,socket,gemini,cursor,9router -c cyan,blue,green,yellow,magenta \"pnpm run dev\" \"pnpm run start:socket\" \"pnpm run start:bridge\" \"pnpm run start:bridge:cursor\" \"pnpm run start:bridge:ninerouter\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start:all-bridges": "concurrently -n socket,gemini,cursor,9router -c blue,green,yellow,magenta \"pnpm run start:socket\" \"pnpm run start:bridge\" \"pnpm run start:bridge:cursor\" \"pnpm run start:bridge:ninerouter\"",
    "start:socket": "tsx -r dotenv/config src/socket/server.ts",
    "start:bridge": "tsx -r dotenv/config src/bridge/gemini-bridge.ts",
    "start:bridge:cursor": "tsx -r dotenv/config src/bridge/bridge.ts",
    "start:bridge:ninerouter": "tsx -r dotenv/config src/bridge/ninerouter-bridge.ts"
  },
  "keywords": [
    "knitto",
    "browser",
    "agent",
    "mcp",
    "puppeteer",
    "cursor"
  ],
  "author": "knittotextile",
  "license": "ISC",
  "dependencies": {
    "@connectrpc/connect-node": "^1.6.1",
    "@cursor/sdk": "^1.0.19",
    "@google/genai": "^2.8.0",
    "@modelcontextprotocol/sdk": "^1.0.1",
    "@tiptap/extension-placeholder": "^3.27.0",
    "@tiptap/markdown": "^3.27.0",
    "@tiptap/pm": "^3.27.0",
    "@tiptap/react": "^3.27.0",
    "@tiptap/starter-kit": "^3.27.0",
    "dotenv": "^17.4.2",
    "puppeteer": "^24.8.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "ws": "^8.18.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^10.0.3",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.4"
  }
}
