{
  "name": "knitto-browser-agent",
  "version": "1.0.0",
  "description": "Knitto Browser Agent — frontend + backend monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "concurrently -n frontend,backend -c cyan,green \"pnpm --filter @knitto/frontend dev\" \"pnpm --filter @knitto/backend dev\"",
    "dev:frontend": "pnpm --filter @knitto/frontend dev",
    "dev:backend": "pnpm --filter @knitto/backend dev",
    "build": "pnpm --filter @knitto/shared --filter @knitto/backend --filter @knitto/frontend build",
    "start": "pnpm --filter @knitto/backend start"
  },
  "keywords": [
    "knitto",
    "browser",
    "agent",
    "puppeteer"
  ],
  "author": "knittotextile",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^10.0.3",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
