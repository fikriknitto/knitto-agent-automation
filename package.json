{
  "name": "knitto-browser-agent",
  "version": "1.0.0",
  "description": "Knitto Browser Agent — frontend + backend monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": "24.16.0",
    "pnpm": "11.5.2"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:frontend": "turbo run dev --filter=@knitto/frontend",
    "dev:backend": "turbo run dev --filter=@knitto/backend",
    "dev:shared": "pnpm --filter @knitto/shared build",
    "build": "turbo run build",
    "build:shared": "pnpm --filter @knitto/shared build",
    "build:backend": "pnpm --filter @knitto/backend build",
    "build:frontend": "pnpm --filter @knitto/frontend build",
    "typecheck": "turbo run typecheck",
    "start": "pnpm --filter @knitto/backend start",
    "preview": "pnpm --filter @knitto/frontend preview",
    "clean": "pnpm -r exec node -e \"try{require('fs').rmSync('dist',{recursive:true,force:true})}catch{}\"",
    "start:instances": "tsx --env-file=apps/backend/.env scripts/start-instance.ts",
    "connect:instances": "tsx --env-file=apps/backend/.env scripts/connect-instance.ts",
    "close:instances": "tsx --env-file=apps/backend/.env scripts/close-instance.ts",
    "disconnect:instances": "tsx --env-file=apps/backend/.env scripts/disconnect-instance.ts",
    "instances:up": "pnpm start:instances --emulator=3 && pnpm connect:instances",
    "instances:down": "pnpm close:instances && pnpm disconnect:instances"
  },
  "keywords": [
    "knitto",
    "browser",
    "agent",
    "puppeteer",
    "monorepo"
  ],
  "author": "knittotextile",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^24.13.2",
    "tsx": "^4.7.1",
    "turbo": "^2.10.0",
    "typescript": "^5.3.3"
  }
}
