# Defaults for Docker Compose (override via root .env if needed)
BACKEND_HOST=0.0.0.0
BACKEND_PORT=3080

GEMINI_API_KEY=
CURSOR_API_KEY=

KNITTO_BRIDGE_MODEL=gemini-2.5-flash
KNITTO_BRIDGE_MAX_CONCURRENT=1
KNITTO_BRIDGE_JOB_TIMEOUT_MS=600000
KNITTO_BRIDGE_MAX_TOOL_CALLS=40

AUTOMATION_HEADLESS=true
AUTOMATION_VIEWPORT_WIDTH=1366
AUTOMATION_VIEWPORT_HEIGHT=768
AUTOMATION_RECORD_VIDEO=true
AUTOMATION_RECORD_FPS=20
AUTOMATION_FFMPEG_PATH=/usr/bin/ffmpeg
AUTOMATION_MCP_COMMAND=node
AUTOMATION_MCP_PATH=apps/backend/dist/automation/mcp-stdio-server.js

STORAGE_ROOT=./storage
STORAGE_MAX_UPLOAD_BYTES=52428800

NINEROUTER_BASE_URL=http://host.docker.internal:20128
NINEROUTER_API_KEY=
NINEROUTER_MODEL=
NINEROUTER_MAX_RETRIES=5
NINEROUTER_RETRY_DELAY_MS=2000

KNITTO_MCP_LOG_LEVEL=info

PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
