# Konfigurasi dipindah ke masing-masing app:
#   apps/backend/.env   — server, AI keys, Puppeteer, storage
#   apps/frontend/.env  — Vite dev server & proxy ke backend
#
# Salin dari .env.example di folder yang sama:
#   cp apps/backend/.env.example apps/backend/.env
#   cp apps/frontend/.env.example apps/frontend/.env
