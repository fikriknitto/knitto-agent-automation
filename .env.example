# Optional overrides for `docker compose` (copy to `.env` di root repo).
# Secrets di sini menimpa nilai kosong di docker.env.

GEMINI_API_KEY=
CURSOR_API_KEY=
NINEROUTER_API_KEY=

FRONTEND_PORT=3000
BACKEND_PORT=3080

# Opsional — default sudah di docker.env
# NINEROUTER_BASE_URL=http://host.docker.internal:20128
# APPIUM_SERVER_URL=http://host.docker.internal:4723
# ADB_SERVER_SOCKET=tcp:host.docker.internal:5037
