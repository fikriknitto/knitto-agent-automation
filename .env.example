# =============================================================================
# Root `.env` untuk Docker Compose (salin: cp .env.example .env)
# Nilai di sini menimpa secret/port + opsi host-gateway di docker-compose.yml.
# Runtime container lainnya: docker.env
# =============================================================================

# Ports (host → container)
FRONTEND_PORT=3000
BACKEND_PORT=3080
APPIUM_PORT=4723

# AI providers (disarankan diisi di sini, kosong di docker.env)
GEMINI_API_KEY=
CURSOR_API_KEY=
NINEROUTER_API_KEY=

# Host services dari dalam container
NINEROUTER_BASE_URL=http://host.docker.internal:20128
# Appium = service Compose (hostname `appium`)
APPIUM_SERVER_URL=http://appium:4723
# Backend UI device list — ADB server host (adb -a nodaemon server start)
ADB_SERVER_SOCKET=tcp:host.docker.internal:5037
# Appium container — adb connect ke port ADB emulator di host (bukan ADB_SERVER_SOCKET)
# Multi: host.docker.internal:5555,host.docker.internal:5556
ADB_CONNECT_TARGETS=host.docker.internal:5555
