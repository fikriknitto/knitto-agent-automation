# =============================================================================
# Vite dev server
# =============================================================================
VITE_DEV_PORT=3000

# =============================================================================
# Backend API (direct — no Vite proxy)
# Production build: leave unset or empty for same-origin /api via nginx.
# =============================================================================
VITE_BASE_URL_BACKEND=http://localhost:3080

# =============================================================================
# Default connection panel (WebSocket)
# Harus selaras dengan BACKEND_PORT di apps/backend/.env
# =============================================================================
VITE_WS_HOST=localhost
VITE_WS_PORT=3080
VITE_DEFAULT_CHANNEL=automation-default

# =============================================================================
# API Data (Knitto Api Automation QA Data) — W2 create-before-WS
# Login JWT di Settings → Connection. Default port API Data = 8009.
# =============================================================================
VITE_API_DATA_BASE_URL=http://localhost:8009
