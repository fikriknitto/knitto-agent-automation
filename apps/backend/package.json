{
  "name": "@knitto/backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx -r dotenv/config src/server.ts",
    "dev:watch": "tsx watch -r dotenv/config src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run build && node --test dist/services/shared/segment-context.test.js dist/services/shared/segment-state-file.test.js dist/services/shared/segment-recording.test.js dist/services/shared/multi-tc-close-guard.test.js dist/services/shared/app-memory-sections.test.js dist/automation/libs/browser/session-page.test.js dist/automation/libs/browser/session-reconnect.test.js dist/mobile-automation/libs/mobile-session-state.test.js dist/mobile-automation/libs/mobile-session-cleanup.test.js dist/mobile-automation/libs/mobile-recording.test.js dist/mobile-automation/libs/mobile-job-context-segment.test.js",
    "start": "node -r dotenv/config dist/server.js"
  },
  "dependencies": {
    "@connectrpc/connect-node": "^1.6.1",
    "@cursor/sdk": "^1.0.19",
    "@knitto/shared": "workspace:*",
    "@knittotextile/knitto-agent-core": "1.1.0",
    "@knittotextile/knitto-agent-providers": "2.0.1",
    "@modelcontextprotocol/sdk": "^1.0.1",
    "ai": "6.0.97",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "fast-xml-parser": "^5.9.3",
    "multer": "^2.2.0",
    "puppeteer": "^24.8.2",
    "puppeteer-screen-recorder": "^3.0.6",
    "webdriverio": "^9.29.1",
    "ws": "^8.18.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.0.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
