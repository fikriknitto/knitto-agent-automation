# =============================================================================
# Server
# =============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=3080

# =============================================================================
# AI providers (opsional — bisa juga lewat Web UI)
# =============================================================================
GEMINI_API_KEY=
CURSOR_API_KEY=

# =============================================================================
# Bridge
# =============================================================================
KNITTO_BRIDGE_MODEL=gemini-2.5-flash
KNITTO_BRIDGE_MAX_CONCURRENT=1
KNITTO_BRIDGE_JOB_TIMEOUT_MS=600000
KNITTO_BRIDGE_MAX_TOOL_CALLS=40

# =============================================================================
# Browser / Puppeteer
# =============================================================================
AUTOMATION_HEADLESS=false
AUTOMATION_VIEWPORT_WIDTH=1366
AUTOMATION_VIEWPORT_HEIGHT=768
AUTOMATION_RECORD_VIDEO=true
AUTOMATION_RECORD_FPS=20
# AUTOMATION_FFMPEG_PATH=C:/ffmpeg/bin/ffmpeg.exe
# Docker production (otomatis di docker.env):
# AUTOMATION_MCP_COMMAND=node
# AUTOMATION_MCP_PATH=apps/backend/dist/automation/mcp-stdio-server.js

# =============================================================================
# File manager (storage/)
# =============================================================================
STORAGE_ROOT=./storage
STORAGE_MAX_UPLOAD_BYTES=52428800

# =============================================================================
# 9Router (opsional)
# =============================================================================
NINEROUTER_BASE_URL=http://localhost:20128
NINEROUTER_API_KEY=
NINEROUTER_MODEL=
NINEROUTER_MAX_RETRIES=5
NINEROUTER_RETRY_DELAY_MS=2000

# =============================================================================
# Mobile / Appium (Android)
# Prasyarat: Appium server + ADB (adb devices). Rekaman video mobile memakai
# Appium startRecordingScreen/stopRecordingScreen — bukan ffmpeg.
# =============================================================================
APPIUM_SERVER_URL=http://127.0.0.1:4723
# MOBILE_UDID=emulator-5554
# MOBILE_DEVICE_UDIDS=emulator-5554,emulator-5556
MOBILE_DEVICE_POOL_ENABLED=true
MOBILE_DEVICE_ACQUIRE_TIMEOUT_MS=60000
MOBILE_IMPLICIT_WAIT_MS=5000
MOBILE_SNAPSHOT_MAX_ELEMENTS=200
MOBILE_RECORD_VIDEO=true
MOBILE_RECORD_TIME_LIMIT_SEC=600
MOBILE_RECORD_FPS=20
MOBILE_RECORD_BIT_RATE=4000000
# MOBILE_VIDEO_FILENAME=recording.mp4
# Interval polling adb devices untuk SSE /api/mobile/devices/stream (ms)
MOBILE_DEVICES_POLL_MS=3000
# TTL cache daftar package per device (ms) — kurangi beban adb pm list
MOBILE_PACKAGES_CACHE_TTL_MS=60000
# MOBILE_MEMORY_DIR=memory/mobile
# MOBILE_UPLOAD_DIR=storage/mobile-uploads
# MOBILE_UPLOAD_MAX_BYTES=52428800
# MOBILE_MCP_PATH=apps/backend/dist/mobile-automation/mcp-stdio-server.js

# =============================================================================
# BlueStacks (Windows) — pnpm start:instances / connect:instances
# Dipakai script di scripts/bluestacks/ (bukan runtime backend).
# =============================================================================
# BLUESTACKS_INSTALL_DIR=C:/Program Files/BlueStacks_nxt
# BLUESTACKS_DATA_DIR=C:/ProgramData/BlueStacks_nxt
# BLUESTACKS_CONF_PATH=
# BLUESTACKS_PLAYER_PATH=
BLUESTACKS_ADB_HOST=127.0.0.1
BLUESTACKS_ADB_CONNECT_DELAY_MS=8000

# =============================================================================
# Logging
# =============================================================================
KNITTO_MCP_LOG_LEVEL=info
