# =============================================================================
# Server
# =============================================================================
NODE_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=3080

# =============================================================================
# AI providers
# =============================================================================
GEMINI_API_KEY=
CURSOR_API_KEY=

# =============================================================================
# Bridge (Gemini / Cursor / 9Router)
# =============================================================================
KNITTO_BRIDGE_MODEL=gemini-2.5-flash
KNITTO_BRIDGE_CWD=
KNITTO_BRIDGE_MAX_CONCURRENT=1
KNITTO_BRIDGE_JOB_TIMEOUT_MS=600000
KNITTO_BRIDGE_MAX_TOOL_CALLS=40

# =============================================================================
# MCP Puppeteer (hanya untuk Cursor SDK subprocess)
# =============================================================================
# Kosong = apps/backend/src/automation/mcp-stdio-server.ts
AUTOMATION_MCP_PATH=

# =============================================================================
# Browser / Puppeteer
# =============================================================================
AUTOMATION_HEADLESS=false
AUTOMATION_SLOW_MO_MS=0
AUTOMATION_BROWSER_TIMEOUT_MS=30000
AUTOMATION_VIEWPORT_WIDTH=1366
AUTOMATION_VIEWPORT_HEIGHT=768

# =============================================================================
# Storage (relatif ke root monorepo jika pakai ./storage)
# =============================================================================
STORAGE_DRIVER=local
STORAGE_ROOT=./storage
STORAGE_MAX_UPLOAD_BYTES=52428800

# =============================================================================
# Automation storage (memory / screenshot / upload legacy)
# =============================================================================
AUTOMATION_MEMORY_DIR=
AUTOMATION_SCREENSHOT_DIR=
AUTOMATION_UPLOAD_DIR=
AUTOMATION_UPLOAD_MAX_BYTES=10485760
AUTOMATION_UPLOAD_CLEANUP=false

# =============================================================================
# 9Router
# =============================================================================
NINEROUTER_BASE_URL=http://localhost:20128
NINEROUTER_API_KEY=
NINEROUTER_MODEL=
NINEROUTER_MAX_RETRIES=5
NINEROUTER_RETRY_DELAY_MS=2000

# =============================================================================
# Logging
# =============================================================================
KNITTO_MCP_LOG_LEVEL=info
